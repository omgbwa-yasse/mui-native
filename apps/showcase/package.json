{
  "name": "mui-native-showcase",
  "version": "1.0.0",
  "private": true,
  "description": "MUI-Native component showcase application",
  "scripts": {
    "generate": "ts-node --project tsconfig.scripts.json scripts/generate-registry.ts",
    "start": "npm run generate && react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^3.36.0",
    "react-native-syntax-highlighter": "^2.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "^0.76.0",
    "@react-native/eslint-config": "^0.76.0",
    "@react-native/metro-config": "^0.76.0",
    "@react-native/typescript-config": "^0.76.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.0",
    "@types/react-native-syntax-highlighter": "^2.0.6",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "ts-node": "^10.9.2",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@mui-native(.*)$": "<rootDir>/../../src$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-syntax-highlighter|react-native-screens|react-native-safe-area-context|react-native-gesture-handler)/)"
    ]
  }
}
